# ── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql://localhost:5432/myapp
DB_NAME=myapp
DB_USER=postgres
DB_PASSWORD=

# ── Cache ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Authentication ────────────────────────────────────────────
JWT_SECRET_KEY=
JWT_EXPIRES_IN=7d
SESSION_SECRET=

# ── Third-party APIs ─────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
SENDGRID_API_KEY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ── App ──────────────────────────────────────────────────────
APP_ENV=development
APP_PORT=3000
APP_URL=http://localhost:3000
DEBUG=false
LOG_LEVEL=info
